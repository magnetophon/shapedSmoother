// ── Quantization helpers ──────────────────────────────────────────────────
// Snap attMs to the grid values the table was measured at.
// Use these to drive the smoother so the correction is exact.
quantizeAttMs(attMs) = overshootATT_MIN_MS
    * pow(overshootATT_MAX_MS / overshootATT_MIN_MS,
          float(attIdx) / float(overshootNATT - 1))
with {
    attIdx = int(0.5 + log(max(overshootATT_MIN_MS,
                              min(overshootATT_MAX_MS, attMs))
                          / overshootATT_MIN_MS)
                      / log(overshootATT_MAX_MS / overshootATT_MIN_MS)
                      * (overshootNATT - 1))
           : max(0) : min(overshootNATT - 1);
};

quantizeShape(s) = float(shapeIdx) / float(overshootNSHAPE - 1)
with {
    shapeIdx = int(0.5 + (s : max(0) : min(1)) * (overshootNSHAPE - 1))
             : max(0) : min(overshootNSHAPE - 1);
};
