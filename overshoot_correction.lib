// overshoot_correction.lib — baked 2D overshoot correction surface.
// GENERATED by gen_overshoot_correction.sh, do not hand-edit.
// degree (6,6) tensor-product fit in (u,v)
//   u = 2·log(attSamp/2.2080)/log(2400.0/2.2080) − 1
//   v = 2·shapeSlider − 1
// training SR: 48000 Hz  (att_samples range [2.2080, 2400.0])
// floor cutoff: 100 samples (overshoot zeroed above this for the fit)
// max abs residual (≤100 samp): 1.73e-01;  max measured overshoot: 5.071607e-01
// grid: 32×32 (att × shape)
// source of truth: shapedSmoother_core.dsp (env loop, curve functions) via library().
// regenerate: FLOOR_CUTOFF=100 gen_overshoot_correction.sh shapedSmoother_core.dsp 6 6 32 32 48000
//
// Usage:  import("overshoot_correction.lib");
//         correction = overshootCorrection(att_samples, shapeSlider);
//   where att_samples = att * ma.SR : max(1)  (number of attack steps)
//         shapeSlider ∈ [0,1]  (the raw attack-shape slider value)
//   Returns the overshoot magnitude (≥ 0): how far below 0 the
//   envelope goes on a unit step with those parameters.
// ============================================================================

overshootCorrection(att_samples, shapeSlider) =
    poly(att_samples, shapeSlider : max(0) : min(1)) : max(0) : min(1)
with {
    ATT_MIN_SAMP = 2.208;
    ATT_MAX_SAMP = 2400.0;
    LOG_RATIO    = 6.991136887921188;

    poly(a_samp, s) = row0 + u*(row1 + u*(row2 + u*(row3 + u*(row4 + u*(row5 + u*(row6)))))) with {
        // log-normalize att_samples to [−1, 1], clamped to training range
        u = 2 * log(max(ATT_MIN_SAMP, min(ATT_MAX_SAMP, a_samp))
                    / ATT_MIN_SAMP)
              / LOG_RATIO - 1;
        v = 2*s - 1;
        row0 = a0_0 + v*(a0_1 + v*(a0_2 + v*(a0_3 + v*(a0_4 + v*(a0_5 + v*(a0_6))))));
        row1 = a1_0 + v*(a1_1 + v*(a1_2 + v*(a1_3 + v*(a1_4 + v*(a1_5 + v*(a1_6))))));
