quantizeAttSamples(att_samples) = select2(att_samples > overshootATT_MAX_SAMP,
    overshootATT_MIN_SAMP
        * pow(overshootATT_MAX_SAMP / overshootATT_MIN_SAMP,
              float(attIdx) / float(overshootNATT - 1)),
    att_samples)
with {
    attIdx = int(0.5 + log(max(overshootATT_MIN_SAMP,
                              min(overshootATT_MAX_SAMP, att_samples))
                          / overshootATT_MIN_SAMP)
                      / overshootLOG_RATIO * (overshootNATT - 1))
           : max(0) : min(overshootNATT - 1);
};

quantizeShape(s) = float(shapeIdx) / float(overshootNSHAPE - 1)
with {
    shapeIdx = int(0.5 + (s : max(0) : min(1)) * (overshootNSHAPE - 1))
             : max(0) : min(overshootNSHAPE - 1);
};
