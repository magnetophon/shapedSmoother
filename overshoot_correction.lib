        row3 = a3_0 + v*(a3_1 + v*(a3_2 + v*(a3_3 + v*(a3_4 + v*(a3_5 + v*(a3_6))))));
        row4 = a4_0 + v*(a4_1 + v*(a4_2 + v*(a4_3 + v*(a4_4 + v*(a4_5 + v*(a4_6))))));
        row5 = a5_0 + v*(a5_1 + v*(a5_2 + v*(a5_3 + v*(a5_4 + v*(a5_5 + v*(a5_6))))));
        row6 = a6_0 + v*(a6_1 + v*(a6_2 + v*(a6_3 + v*(a6_4 + v*(a6_5 + v*(a6_6))))));
    };
