with {
    poly(x) = a0 + u*(a1 + u*(a2 + u*(a3 + u*(a4 + u*(a5 + u*(a6 + u*(a7 + u*(a8 + u*(a9 + u*(a10 + u*(a11 + u*(a12)))))))))))) with { u = 2*x - 1; };
